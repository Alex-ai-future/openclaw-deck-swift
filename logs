import SwiftUI

// 公共组件：DictationButton
struct DictationButton<Content: View>: View {
    let placeholder: String
    let onDictated: (String) -> Void
    @ViewBuilder let content: () -> Content
    
    @State private var tempText = ""
    @FocusState private var isDictating: Bool
    
    var body: some View {
        HStack(alignment: .center) {
            content()
            
            Button {
                isDictating = true
            } label: {
                Image(systemName: isDictating ? "mic.fill" : "mic")
                    .font(.title2)
                    .foregroundStyle(isDictating ? .red : .accentColor)
                    .padding(10)
            }
            .buttonStyle(.plain)
        }
        // 隐藏的触发器
        .overlay {
            TextField("", text: $tempText)
                .focused($isDictating)
                .frame(width: 1, height: 1)
                .opacity(0)
                .allowsHitTesting(false)
                .onChange(of: tempText) { newValue in
                    // 实时累加或替换
                    onDictated(newValue)
                    tempText = ""  // 清空，准备下一次
                }
                .onChange(of: isDictating) { new in
                    if !new && !tempText.isEmpty {
                        onDictated(tempText)
                        tempText = ""
                    }
                }
        }
        .ignoresSafeArea(.keyboard)
    }
}