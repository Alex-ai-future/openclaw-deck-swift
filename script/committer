#!/bin/bash
# committer - 安全的 Git 提交脚本
# 用法：./script/committer "<提交信息>" <文件1> [文件2] [文件3...]
#
# 示例：
#   ./script/committer "[feature] 添加搜索功能" Sources/Views/SearchView.swift Sources/Managers/SearchManager.swift
#   ./script/committer "[fix] 修复崩溃问题" Sources/AppDelegate.swift

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# 检查参数
if [ $# -lt 2 ]; then
    echo -e "${RED}错误：参数不足${NC}"
    echo ""
    echo "用法：$0 \"<提交信息>\" <文件 1> [文件 2] [文件 3...]"
    echo ""
    echo "示例："
    echo "  $0 \"[feature] 添加搜索功能\" Sources/Views/SearchView.swift Sources/Managers/SearchManager.swift"
    echo "  $0 \"[fix] 修复崩溃问题\" Sources/AppDelegate.swift"
    echo ""
    echo "提交类型："
    echo "  [feature]  - 新功能"
    echo "  [fix]      - 修复 bug"
    echo "  [ui]       - UI 改进"
    echo "  [refactor] - 重构"
    echo "  [docs]     - 文档更新"
    exit 1
fi

# 获取提交信息（第一个参数）
COMMIT_MSG="$1"
shift

# 获取文件列表（剩余参数）
FILES=("$@")

# 检查文件是否存在且有修改
echo -e "${YELLOW}检查文件状态...${NC}"
VALID_FILES=()
for file in "${FILES[@]}"; do
    if [ ! -f "$file" ]; then
        echo -e "${RED}警告：文件不存在，跳过：$file${NC}"
        continue
    fi
    
    # 检查文件是否有修改（包括未跟踪的新文件）
    if git diff --quiet -- "$file" 2>/dev/null && git diff --cached --quiet -- "$file" 2>/dev/null && git ls-files --error-unmatch -- "$file" &>/dev/null; then
        echo -e "${YELLOW}警告：文件没有修改，跳过：$file${NC}"
        continue
    fi
    
    VALID_FILES+=("$file")
done

# 如果没有有效文件，退出
if [ ${#VALID_FILES[@]} -eq 0 ]; then
    echo -e "${RED}错误：没有要提交的文件${NC}"
    exit 1
fi

# 显示将要提交的文件
echo -e "${GREEN}将要提交的文件：${NC}"
for file in "${VALID_FILES[@]}"; do
    echo "  - $file"
done
echo ""

# 显示提交信息
echo -e "${GREEN}提交信息：${NC}$COMMIT_MSG"
echo ""

# 执行 git add（先 add，让 format.sh 可以检测到暂存的文件）
echo -e "${YELLOW}添加文件到暂存区...${NC}"
git add "${VALID_FILES[@]}"

# 格式化暂存的 Swift 文件
echo -e "${YELLOW}格式化 Swift 代码...${NC}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
"$SCRIPT_DIR/format.sh" --staged

# 重新添加格式化后的文件
SWIFT_FILES=$(git diff --name-only --cached | grep '\.swift$' || true)
if [ -n "$SWIFT_FILES" ]; then
    echo -e "${GREEN}✅ 已格式化：${NC}"
    echo "$SWIFT_FILES" | sed 's/^/  /'
    git add $SWIFT_FILES
fi

# 执行 git commit
echo -e "${YELLOW}提交代码...${NC}"
if git commit -m "$COMMIT_MSG"; then
    echo ""
    echo -e "${GREEN}✅ 提交成功！${NC}"
    echo ""
    echo "提交信息：$COMMIT_MSG"
    echo "提交文件：${#VALID_FILES[@]} 个"
else
    echo -e "${RED}❌ 提交失败${NC}"
    exit 1
fi
